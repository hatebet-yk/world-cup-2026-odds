  "computeStandings": "function computeStandings(groupData) {\n  const standings = {};\n  for (const team of groupData.teams) {\n    standings[team] = { pts: 0, gp: 0, w: 0, d: 0, l: 0, gf: 0, ga: 0, gd: 0 };\n  }\n  for (const m of groupData.matches) {\n    if (m.status !== \"finished\" || m.score1 === null) continue;\n    const t1 = m.team1, t2 = m.team2;\n    standings[t1].gp++;\n    standings[t2].gp++;\n    standings[t1].gf += m.score1;\n    standings[t1].ga += m.score2;\n    standings[t2].gf += m.score2;\n    standings[t2].ga += m.score1;\n    if (m.score1 > m.score2) {\n      standings[t1].w++;\n      standings[t1].pts += 3;\n      standings[t2].l++;\n    } else if (m.score1 < m.score2) {\n      standings[t2].w++;\n      standings[t2].pts += 3;\n      standings[t1].l++;\n    } else {\n      standings[t1].d++;\n      standings[t2].d++;\n      standings[t1].pts++;\n      standings[t2].pts++;\n    }\n  }\n  return standings;\n}"
}